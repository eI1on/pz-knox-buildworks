{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "KnoxBuildworks/buildables.schema.json",
  "title": "Knox Buildworks definition bundle v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "buildables"
  ],
  "$defs": {
    "input": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "role": {
          "enum": [
            "material",
            "tool",
            "consumable",
            "component",
            "resource"
          ]
        },
        "mode": {
          "enum": [
            "consume",
            "keep",
            "drain",
            "destroy"
          ]
        },
        "resourceType": {
          "enum": [
            "Item",
            "Fluid",
            "Energy"
          ]
        },
        "label": {
          "type": "string"
        },
        "labelKey": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "amount": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "amountMax": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "uses": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "materialTags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "items"
          ]
        },
        {
          "required": [
            "tags"
          ]
        }
      ]
    },
    "localizedOption": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "translationKey": {
          "type": "string"
        },
        "labelKey": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "group": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "translationKey": {
          "type": "string"
        },
        "level": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cell": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "boolean"
        },
        {
          "type": "object",
          "properties": {
            "sprite": {
              "type": "string"
            },
            "empty": {
              "type": "boolean"
            },
            "blocks": {
              "type": "boolean"
            },
            "kind": {
              "type": "string"
            },
            "properties": {
              "type": "object"
            }
          }
        }
      ]
    },
    "face": {
      "type": "object",
      "required": [
        "layers"
      ],
      "properties": {
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "rows"
            ],
            "properties": {
              "rows": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/cell"
                  }
                }
              }
            }
          }
        }
      }
    },
    "placement": {
      "type": "object",
      "description": "Knox-owned placement rules. These work with or without entityCompat.",
      "properties": {
        "kind": {
          "enum": [
            "object",
            "wall",
            "floor",
            "stairs",
            "overlay",
            "wallCovering"
          ]
        },
        "requiresFloor": {
          "type": "boolean"
        },
        "maxDistance": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "againstWall": {
          "type": "boolean"
        },
        "needToBeAgainstWall": {
          "type": "boolean"
        },
        "dontNeedFrame": {
          "type": "boolean"
        },
        "needWindowFrame": {
          "type": "boolean"
        },
        "isPole": {
          "type": "boolean"
        },
        "wallCoveringType": {
          "enum": [
            "plaster",
            "paint",
            "paintThump",
            "wallpaper",
            "paintSign"
          ]
        },
        "sign": {
          "type": [
            "integer",
            "string",
            "null"
          ]
        }
      }
    },
    "construction": {
      "type": "object",
      "description": "Knox-owned build-action metadata. It does not create a native CraftRecipe component.",
      "properties": {
        "time": {
          "type": "number",
          "minimum": 0
        },
        "timedAction": {
          "type": "string",
          "minLength": 1
        },
        "sound": {
          "type": "string",
          "minLength": 1
        },
        "completionSound": {
          "type": "string",
          "minLength": 1
        },
        "actionAnim": {
          "type": "string",
          "minLength": 1
        },
        "animVariable": {
          "type": "object",
          "required": [
            "key",
            "value"
          ],
          "properties": {
            "key": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "canWalk": {
          "type": "boolean"
        },
        "category": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "xp": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "objectConfig": {
      "type": "object",
      "description": "World-object flags applied by the Knox construction path; no engine component is created.",
      "properties": {
        "isThumpable": {
          "type": "boolean"
        },
        "isProp": {
          "type": "boolean"
        },
        "dismantable": {
          "type": "boolean"
        },
        "blockAllSquare": {
          "type": "boolean"
        },
        "canPassThrough": {
          "type": "boolean"
        },
        "hoppable": {
          "type": "boolean"
        },
        "canBarricade": {
          "type": "boolean"
        },
        "canBePadlocked": {
          "type": "boolean"
        },
        "thumpDamage": {
          "type": "number",
          "minimum": 0
        },
        "breakSound": {
          "type": "string"
        },
        "cornerSprite": {
          "type": "string"
        },
        "buildLow": {
          "type": "boolean"
        },
        "drawFloorGrid": {
          "type": "boolean"
        }
      }
    },
    "callbacks": {
      "type": "object",
      "description": "Optional namespaced Lua overrides invoked by Knox with its documented compatibility payload. JSON-only floors receive Knox-owned placement and creation lifecycle callbacks when the corresponding fields are omitted. Callback portability still depends on the function's object, recipe-data, sprite, and native-system assumptions.",
      "properties": {
        "onAddToMenu": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)+$"
        },
        "onCreate": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)+$"
        },
        "onIsValid": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)+$"
        },
        "timedActionOnIsValid": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)+$"
        }
      },
      "additionalProperties": false
    },
    "lightOffset": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "lightSource": {
      "type": "object",
      "required": [
        "radius"
      ],
      "description": "Knox-created thumpable light source. Provide item and/or tags unless debugItem is cheat-only.",
      "properties": {
        "radius": {
          "type": "integer",
          "minimum": 1
        },
        "item": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fuel": {
          "type": "string"
        },
        "debugItem": {
          "type": "string"
        },
        "offsets": {
          "type": "object",
          "propertyNames": {
            "enum": [
              "N",
              "E",
              "S",
              "W"
            ]
          },
          "additionalProperties": {
            "$ref": "#/$defs/lightOffset"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "item"
          ]
        },
        {
          "required": [
            "tags"
          ]
        },
        {
          "required": [
            "debugItem"
          ]
        }
      ]
    }
  },
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "templates": {
      "type": "object"
    },
    "materialGroups": {
      "type": "object"
    },
    "buildables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "stages"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+$"
          },
          "extends": {
            "type": "string"
          },
          "translationKey": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "descriptionKey": {
            "type": "string"
          },
          "tooltipKey": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "iconName": {
            "type": "string"
          },
          "iconTexture": {
            "type": "string"
          },
          "iconItem": {
            "type": "string"
          },
          "iconSprite": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "subcategory": {
            "type": "string"
          },
          "material": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "materialTags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "styleTags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowSpriteReuse": {
            "type": "boolean",
            "description": "Explicitly allows this definition to share its sprites with other definitions that also opt in."
          },
          "group": {
            "$ref": "#/$defs/group"
          },
          "variants": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/localizedOption"
            }
          },
          "materialOptions": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/localizedOption"
            }
          },
          "materialRequired": {
            "type": "boolean",
            "description": "When true the base stages are not buildable on their own; a materialOptions entry must always be selected, and the UI offers no base-material row."
          },
          "tools": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/input"
            }
          },
          "placement": {
            "$ref": "#/$defs/placement"
          },
          "construction": {
            "$ref": "#/$defs/construction"
          },
          "finishes": {
            "type": "object",
            "description": "Wall finish surface and sprite mapping. paintRequiresPlaster/wallpaperRequiresPlaster default to true.",
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "wallType": {
                "type": "string"
              },
              "paints": {
                "type": [
                  "array",
                  "boolean"
                ],
                "items": {
                  "type": "string"
                }
              },
              "wallpapers": {
                "type": [
                  "array",
                  "boolean"
                ],
                "items": {
                  "type": "string"
                }
              },
              "surface": {
                "type": "object",
                "properties": {
                  "canPlaster": {
                    "type": "boolean"
                  },
                  "canPaint": {
                    "type": "boolean"
                  },
                  "canWallpaper": {
                    "type": "boolean"
                  },
                  "paintRequiresPlaster": {
                    "type": "boolean"
                  },
                  "wallpaperRequiresPlaster": {
                    "type": "boolean"
                  }
                }
              },
              "mapping": {
                "type": "object",
                "properties": {
                  "plaster": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "paints": {
                    "type": "object"
                  },
                  "wallpapers": {
                    "type": "object"
                  },
                  "directPaints": {
                    "type": "object"
                  },
                  "directWallpapers": {
                    "type": "object"
                  },
                  "baseSprites": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "surface": {
                    "type": "object",
                    "description": "Legacy inline location for surface capabilities. Prefer finishes.surface."
                  }
                }
              }
            }
          },
          "spritePattern": {
            "type": "object"
          },
          "postBuildActions": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "stages": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "level": {
                  "type": "integer",
                  "minimum": 1
                },
                "translationKey": {
                  "type": "string"
                },
                "labelKey": {
                  "type": "string"
                },
                "displayName": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "previousStage": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string"
                      }
                    }
                  ]
                },
                "icon": {
                  "type": "string"
                },
                "iconName": {
                  "type": "string"
                },
                "iconTexture": {
                  "type": "string"
                },
                "iconItem": {
                  "type": "string"
                },
                "iconSprite": {
                  "type": "string"
                },
                "health": {
                  "type": "number"
                },
                "skillBaseHealth": {
                  "type": "number"
                },
                "bonusHealth": {
                  "type": "number"
                },
                "xp": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "number",
                    "minimum": 0
                  }
                },
                "object": {
                  "$ref": "#/$defs/objectConfig"
                },
                "callbacks": {
                  "$ref": "#/$defs/callbacks"
                },
                "lightSource": {
                  "$ref": "#/$defs/lightSource"
                },
                "placement": {
                  "$ref": "#/$defs/placement"
                },
                "construction": {
                  "$ref": "#/$defs/construction"
                },
                "allowSpriteReuse": {
                  "type": "boolean",
                  "description": "Explicitly allows this stage to share its sprites with other opted-in definitions."
                },
                "finishes": {
                  "type": "object"
                },
                "finishOptions": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                },
                "entityCompat": {
                  "type": "object",
                  "description": "Reference to an already-registered B42 GameEntityScript. Native component metadata is derived from that script at runtime and must not be copied into JSON.",
                  "required": [
                    "entity"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "module": {
                      "type": "string"
                    },
                    "entity": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                "sprites": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "geometry": {
                  "type": "object",
                  "properties": {
                    "faces": {
                      "type": "object",
                      "propertyNames": {
                        "enum": [
                          "N",
                          "E",
                          "S",
                          "W"
                        ]
                      },
                      "additionalProperties": {
                        "$ref": "#/$defs/face"
                      }
                    }
                  }
                },
                "requirements": {
                  "type": "object",
                  "properties": {
                    "inputs": {
                      "type": "array",
                      "items": {
                        "$ref": "#/$defs/input"
                      }
                    },
                    "materials": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "array",
                          "items": {
                            "$ref": "#/$defs/input"
                          }
                        }
                      ]
                    },
                    "tools": {
                      "type": "array",
                      "items": {
                        "$ref": "#/$defs/input"
                      }
                    },
                    "skills": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "integer",
                        "minimum": 0
                      }
                    },
                    "knowledge": {
                      "type": "object"
                    },
                    "recipes": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "debugOnly": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
